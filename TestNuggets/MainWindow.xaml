<Window x:Class="TestNuggets.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="TestNuggets - Material Design"
        Height="500"
        Width="800"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid>
        <materialDesign:Card Margin="204,37,215,74"
                             Padding="20"
                             UniformCornerRadius="10"
                             Background="{DynamicResource MaterialDesignPaper}">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Height="321">

                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Text="Enter your name"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center" />

                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="260"
                         materialDesign:HintAssist.Hint="Your name here..."
                         materialDesign:HintAssist.IsFloating="True"
                         FontSize="16"
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

                <!-- NOVÉ: Zobrazíme počet znakov -->
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Text="{Binding NameLength, StringFormat='Počet znakov: {0}'}" />

                <!-- Hlavné tlačidlo -->
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,20,0,0"
                        Width="180"
                        Height="50"
                        FontSize="16"
                        Command="{Binding GreetCommand}">
                    Greet
                </Button>

                <!-- NOVÉ: Tlačidlo Clear -->
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,10,0,0"
                        Width="180"
                        Height="45"
                        FontSize="15"
                        Command="{Binding ClearCommand}">
                    Clear Name
                </Button>
                <Button Style="{StaticResource MaterialDesignOutlinedDarkButton}"
                        Margin="0,10,0,0"
                        Width="180"
                        Height="45"
                        FontSize="15"
                        Command="{Binding UpperCaseCommand}">
                    Upper case Name
                </Button>

            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
