<Window x:Class="Wpf_Pokemons.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_Pokemons"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Grid>
        <Button Name="Start_Button"
                Content="Start"
                HorizontalAlignment="Center"
                Margin="0,290,0,0"
                VerticalAlignment="Top"
                Height="92"
                Width="252"
                FontSize="24"
                FontFamily="Arial Black"
                Click="Start_Button_Click" />
        <Image Name="Charmander"
               Source="/Images/charmander.png"
               HorizontalAlignment="Left"
               Height="142"
               Margin="128,124,0,0"
               VerticalAlignment="Top"
               Width="133"
               RenderOptions.BitmapScalingMode="HighQuality" />
        <Image Name="Charmeleon"
               Source="/Images/charmeleon.png"
               HorizontalAlignment="Left"
               Height="142"
               Margin="342,124,0,0"
               VerticalAlignment="Top"
               Width="132"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderTransformOrigin="0.445,0.85" />
        <Image Name="Charizard"
               Source="/Images/Charizard.png"
               HorizontalAlignment="Left"
               Height="155"
               Margin="519,111,0,0"
               VerticalAlignment="Top"
               Width="131"
               RenderOptions.BitmapScalingMode="HighQuality" />
        <Label Content="Pick enemy"
               HorizontalAlignment="Left"
               Margin="226,10,0,0"
               VerticalAlignment="Top"
               Height="67"
               Width="331"
               FontSize="40" />
        <Button Name="Charmander_button"
                Content=""
                HorizontalAlignment="Left"
                Margin="128,124,0,0"
                VerticalAlignment="Top"
                Height="142"
                Width="125"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Charmander_button_Click" 
                />
        <Button Name="Charmeleon_button"
                Content=""
                HorizontalAlignment="Left"
                Margin="333,124,0,0"
                VerticalAlignment="Top"
                Height="142"
                Width="125"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Charmeleon_button_Click" />
        <Button Name="Charizard_button"
                Content=""
                HorizontalAlignment="Left"
                Margin="519,124,0,0"
                VerticalAlignment="Top"
                Height="142"
                Width="125"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Charizard_button_Click" />
        <Image x:Name="test"
            HorizontalAlignment="Left"
               Height="120"
               Margin="32,290,0,0"
               VerticalAlignment="Top"
               Width="124" />
    </Grid>
</Window>
