<Window x:Class="Wpf_Pokemons.Window_Fight"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_Pokemons"
        mc:Ignorable="d"
        Title="Window_Fight"
        Height="450"
        Width="800">
    <Grid>
        <Image Name="Hero_Image"
               HorizontalAlignment="Left"
               Height="215"
               Margin="49,15,0,0"
               VerticalAlignment="Top"
               Width="202"
               Source="/Images/Pikachu.png"
               RenderOptions.BitmapScalingMode="HighQuality" />
        <Image HorizontalAlignment="Left"
               Height="255"
               Name="EnemyPic"
               Margin="541,10,0,0"
               VerticalAlignment="Top"
               Width="210"
               Source="/Images/Charizard.png"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <ProgressBar Name="ProgressBar_Hero"
                     HorizontalAlignment="Left"
                     Height="19"
                     Margin="10,260,0,0"
                     VerticalAlignment="Top"
                     Width="160"
                     Maximum="150" />
        <ProgressBar Name="ProgressBar_Monster"
                     HorizontalAlignment="Left"
                     Height="18"
                     Margin="505,260,0,0"
                     VerticalAlignment="Top"
                     Width="258"
                     Maximum="150" />
        <Button Name="Button_LightAttack"
                Content="Light Attack"
                HorizontalAlignment="Left"
                Margin="21,300,0,0"
                VerticalAlignment="Top"
                Height="32"
                Width="83"
                FontSize="14"
                Click="Button_LightAttack_Click" />

        <Button Name="Button_MediumAttack"
                Content="Medium Attack"
                HorizontalAlignment="Left"
                Margin="120,300,0,0"
                VerticalAlignment="Top"
                Height="32"
                Width="100"
                FontSize="15"
                Click="Button_Click" />

        <Button Name="Button_CriticalAttack"
                Content="Critical Attack"
                HorizontalAlignment="Left"
                Margin="230,300,0,0"
                VerticalAlignment="Top"
                FontSize="15"
                Height="32"
                Width="98"
                Click="Button_Click_1" />
        <Label Name="Label_Death"
               Content=""
               HorizontalAlignment="Left"
               Margin="279,93,0,0"
               VerticalAlignment="Top"
               Height="109"
               Width="230"
               FontSize="50" />
        <ProgressBar Name="Energy_bar"
                     HorizontalAlignment="Left"
                     Height="19"
                     Margin="182,260,0,0"
                     VerticalAlignment="Top"
                     Width="161"
                     Foreground="Yellow" />
        <Button Name="Button_Heal"
                Content="Heal"
                HorizontalAlignment="Left"
                Margin="21,359,0,0"
                VerticalAlignment="Top"
                Height="32"
                Width="83"
                FontSize="14"
                Click="Button_HealAttack_Click" />
        <Button Name="Button_Restart"
                Content="Restart"
                HorizontalAlignment="Center"
                Margin="0,370,0,0"
                VerticalAlignment="Top"
                Height="40"
                Width="104"
                FontSize="14"
                Click="Button_Restart_Click" />
        <Label Name="Hero_Health"
               Content="150/150"
               HorizontalAlignment="Left"
               Margin="16,230,0,0"
               VerticalAlignment="Top"
               Height="25" />
        <Button Name="Button_Energy"
                Content="Reboot energy"
                HorizontalAlignment="Left"
                Margin="120,359,0,0"
                VerticalAlignment="Top"
                Height="32"
                Width="104"
                FontSize="14"
                Click="Button_EnergyReboot_Click" />
    </Grid>
</Window>
