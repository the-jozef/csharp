<Window x:Class="Wpf_website.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Wpf_website"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Windown_name"
        Width="900"
        Height="550"
        MinWidth="500"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        mc:Ignorable="d">
    <Border CornerRadius="15"
            BorderThickness="0.5"
            BorderBrush="MediumPurple">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="105" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border CornerRadius="14.7,0,0,14.7"
                    Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0.6">
                        <GradientStop Color="#FF8FC8CF"
                                      Offset="0" />
                        <GradientStop Color="#FF56AEE5"
                                      Offset="1." />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <StackPanel>
                        <Image Name="Logo"    
                               Source="/Images/Logo.png"
                               Height="70"
                               Width="100"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Left" 
                               Cursor="Hand"/>
                    </StackPanel>
                    <RadioButton Background="Transparent"
                                 Cursor="Hand">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Grid>
                                                <Border x:Name="HoverBackground"
                                                        Background="White"
                                                        CornerRadius="5"
                                                        Opacity="0"
                                                        Margin="0" />

                                                <Border x:Name="HoverBar"
                                                        Width="3"
                                                        Background="White"
                                                        HorizontalAlignment="Left"
                                                        Visibility="Collapsed" />

                                                <ContentPresenter Margin="0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter TargetName="HoverBackground"
                                                            Property="Opacity"
                                                            Value="0.2" />
                                                    <Setter TargetName="HoverBar"
                                                            Property="Visibility"
                                                            Value="Visible" />
                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Style>

                        <StackPanel Orientation="Horizontal"
                                    Margin="10,5,5,5">
                            <Image Source="/Images/settings.png"
                                   Height="15"
                                   Width="15"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <TextBlock Text="Settings"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="Black" />
                        </StackPanel>

                    </RadioButton>

                </StackPanel>
            </Border>
            <Border CornerRadius="0,14.7,14.7,0"
                    Grid.Column="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,0.5">
                        <GradientStop Color="#FFA6DBE2"
                                      Offset="0.0" />
                        <GradientStop Color="#FF72B5DF"
                                      Offset="1." />
                    </LinearGradientBrush>

                </Border.Background>
            </Border>

        </Grid>
    </Border>

</Window>
